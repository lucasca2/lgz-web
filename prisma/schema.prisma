generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model candidatos {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome                String                @db.VarChar(255)
  linkedin_url        String                @unique(map: "uq_candidatos_linkedin", where: raw("(deleted_at IS NULL)")) @db.VarChar(512)
  email               String?               @unique(map: "uq_candidatos_email", where: raw("((email IS NOT NULL) AND (deleted_at IS NULL))")) @db.VarChar(255)
  telefone            String?               @db.VarChar(50)
  origem              origem_candidato?
  pretensao_salarial  Decimal?              @db.Decimal(12, 2)
  dados_extraidos     Json?
  deleted_at          DateTime?             @db.Timestamptz(6)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  processos_seletivos processos_seletivos[]
}

model entrevista_participantes {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entrevista_id     String            @db.Uuid
  usuario_id        String            @db.Uuid
  tipo_participacao participacao_tipo @default(Obrigatorio)
  status_convite    convite_status    @default(Sugerido)
  entrevistas       entrevistas       @relation(fields: [entrevista_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios          usuarios          @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([entrevista_id, usuario_id])
  @@index([entrevista_id], map: "idx_participantes_entrevista")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model entrevista_slots {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entrevista_id    String      @unique(map: "uq_slot_escolhido", where: raw("escolhido")) @db.Uuid
  data_hora_inicio DateTime    @db.Timestamptz(6)
  data_hora_fim    DateTime    @db.Timestamptz(6)
  nivel_prioridade Int         @default(1) @db.SmallInt
  escolhido        Boolean     @default(false)
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  entrevistas      entrevistas @relation(fields: [entrevista_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([entrevista_id], map: "idx_slots_entrevista")
}

model entrevistas {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processo_id              String                     @db.Uuid
  etapa_historico_id       String?                    @db.Uuid
  status                   entrevista_status          @default(Aguardando_Escolha)
  link_token               String                     @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  link_expira_em           DateTime?                  @db.Timestamptz(6)
  data_hora_inicio         DateTime?                  @db.Timestamptz(6)
  data_hora_fim            DateTime?                  @db.Timestamptz(6)
  google_event_id          String?                    @db.VarChar(255)
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @default(now()) @db.Timestamptz(6)
  entrevista_participantes entrevista_participantes[]
  entrevista_slots         entrevista_slots?
  historico_etapas         historico_etapas?          @relation(fields: [etapa_historico_id], references: [id], onUpdate: NoAction)
  processos_seletivos      processos_seletivos        @relation(fields: [processo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([processo_id], map: "idx_entrevistas_processo")
}

model etapas_catalogo {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome             String             @unique @db.VarChar(100)
  grupo            String?            @db.VarChar(100)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  historico_etapas historico_etapas[]
  vaga_etapas      vaga_etapas[]
}

model historico_etapas {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processo_id         String              @db.Uuid
  etapa_catalogo_id   String              @db.Uuid
  status_etapa        etapa_status        @default(Em_Andamento)
  data_inicio         DateTime            @default(now()) @db.Timestamptz(6)
  data_fim            DateTime?           @db.Timestamptz(6)
  tempo_pausado_seg   Int                 @default(0)
  transcricao_url     String?             @db.VarChar(512)
  insight_ia          String?
  justificativa       String?
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  entrevistas         entrevistas[]
  etapas_catalogo     etapas_catalogo     @relation(fields: [etapa_catalogo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  processos_seletivos processos_seletivos @relation(fields: [processo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([etapa_catalogo_id], map: "idx_historico_etapa")
  @@index([processo_id], map: "idx_historico_processo")
}

model motivos_reprovacao {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  descricao           String                @unique @db.VarChar(255)
  ativo               Boolean               @default(true)
  processos_seletivos processos_seletivos[]
}

/// Catálogo de posições/cargos por senioridade (ex.: "Backend" + nível "Pleno").
/// Fonte de verdade do que se espera de cada nível; alimenta o cadastro de vagas.
model posicoes {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome                  String                  @db.VarChar(200)
  nivel                 nivel_senioridade
  descricao             String
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  avaliacoes_entrevista avaliacoes_entrevista[]
  vagas                 vagas[]

  @@unique([nome, nivel], map: "uq_posicoes_nome_nivel")
  @@index([nivel], map: "idx_posicoes_nivel")
}

/// Catálogo de projetos/contas (ex.: "TIM", "Sabesp"). Contexto é opcional e
/// preenchido manualmente; alimenta o cadastro de vagas.
model projetos {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome       String   @db.VarChar(200)
  contexto   String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@unique([nome], map: "uq_projetos_nome")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model processos_seletivos {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaga_id               String                  @db.Uuid
  candidato_id          String                  @db.Uuid
  status_atual          processo_status         @default(Em_andamento)
  score_fit_cultural    Int?                    @db.SmallInt
  justificativa_fit     String?
  motivo_reprovacao_id  String?                 @db.Uuid
  comentario_reprovacao String?
  devolutiva_enviada    Boolean                 @default(false)
  tokens_consumidos     Int                     @default(0)
  custo_estimado_usd    Decimal                 @default(0) @db.Decimal(10, 4)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  entrevistas           entrevistas[]
  historico_etapas      historico_etapas[]
  avaliacoes_entrevista avaliacoes_entrevista[]
  candidatos            candidatos              @relation(fields: [candidato_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  motivos_reprovacao    motivos_reprovacao?     @relation(fields: [motivo_reprovacao_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vagas                 vagas                   @relation(fields: [vaga_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vaga_id, candidato_id])
  @@index([candidato_id], map: "idx_processos_candidato")
  @@index([status_atual], map: "idx_processos_status")
  @@index([vaga_id], map: "idx_processos_vaga")
}

model usuarios {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome                     String                     @db.VarChar(255)
  email                    String                     @unique @db.VarChar(255)
  senha_hash               String?
  ativo                    Boolean                    @default(true)
  // ── Perfil Google (login OAuth + agendador) ──
  google_id                String?                    @unique(map: "uq_usuarios_google_id") @db.VarChar(255)
  picture                  String?                    @db.VarChar(1024)
  // Refresh token do recrutador — persistido para "agir como" ele ao revalidar
  // horários e emitir o convite quando o candidato abre o link de agendamento.
  google_refresh_token     String?
  google_scope             String?
  // Token OAuth pessoal do `claude setup-token` (cada usuário usa a própria
  // assinatura do Claude). Alternativa à ANTHROPIC_API_KEY global.
  setup_token              String?
  // API key pessoal (sk-ant-api…) — fallback quando não há setup token.
  api_key                  String?
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @default(now()) @db.Timestamptz(6)
  convites_agendamento     convites_agendamento[]
  entrevista_participantes entrevista_participantes[]
  sessoes                  sessoes[]
  vagas                    vagas[]
}

// ─────────────────────────────────────────────
// Scheduling domain (agendador Google Calendar) — tabela standalone
// ─────────────────────────────────────────────

// Link de convite de agendamento gerado pelo recrutador e consumido UMA ÚNICA
// vez pelo candidato. Ao confirmar (book), status vira CONSUMED e o link fica
// inacessível. Independente do domínio de recrutamento (entrevistas/processos).
model convites_agendamento {
  id String @id @db.VarChar(32) // id curto, usado na URL pública /convite/<id>

  organizador_id    String   @db.Uuid
  organizador       usuarios @relation(fields: [organizador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizador_email String   @db.VarChar(255) // denormalizado: e-mail do organizador

  titulo      String  @db.VarChar(255)
  descricao   String? // descrição do evento (digitada pelo recrutador)
  duracao_min Int     @db.SmallInt
  urgente     Boolean @default(false)

  // Listas de e-mails (string[]) e horários ofertados (ISO string[]).
  incluidos    Json // todos os convidados
  obrigatorios Json // subconjunto obrigatório (trava disponibilidade)
  slots        Json // horários ISO ofertados ao candidato

  // Candidato do board ao qual este convite está atrelado (id do card).
  // Permite o board mostrar "usuário já tem agendamento" e o link do Meet.
  candidato_ref String? @db.VarChar(64)

  // Single-use: ACTIVE até o candidato confirmar; depois CONSUMED.
  status              String    @default("ACTIVE") @db.VarChar(20)
  consumido_em        DateTime? @db.Timestamptz(6)
  consumido_por_email String?   @db.VarChar(255) // e-mail informado pelo candidato
  slot_agendado       String? // horário ISO efetivamente agendado
  google_event_id     String?   @db.VarChar(255)
  google_event_link   String?
  google_meet_link    String? // link da sala do Meet (hangoutLink)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([organizador_id], map: "idx_convites_organizador")
  @@index([candidato_ref], map: "idx_convites_candidato_ref")
}

model vaga_etapas {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaga_id           String          @db.Uuid
  etapa_catalogo_id String          @db.Uuid
  ordem_sugerida    Int             @db.SmallInt
  obrigatoria       Boolean         @default(true)
  etapas_catalogo   etapas_catalogo @relation(fields: [etapa_catalogo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vagas             vagas           @relation(fields: [vaga_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vaga_id, etapa_catalogo_id])
  @@index([vaga_id], map: "idx_vaga_etapas_vaga")
}

model vagas {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo              String                @db.VarChar(255)
  projeto             String                @db.VarChar(255)
  descricao           String?
  status              vaga_status           @default(Aberta)
  prioridade          Int?                  @db.SmallInt
  hiring_manager_id   String?               @db.Uuid
  posicao_id          String?               @db.Uuid
  budget              Decimal?              @db.Decimal(12, 2)
  data_abertura       DateTime              @default(dbgenerated("CURRENT_DATE")) @db.Date
  data_fechamento     DateTime?             @db.Date
  contexto_projeto    Json?
  perfil_ideal        String?
  perfil_rejeitado    String?
  criterios_teste     String?
  prompt_analise      String?
  palavras_chave      String[]
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  processos_seletivos processos_seletivos[]
  vaga_etapas         vaga_etapas[]
  usuarios            usuarios?             @relation(fields: [hiring_manager_id], references: [id], onUpdate: NoAction)
  posicoes            posicoes?             @relation(fields: [posicao_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([status], map: "idx_vagas_status")
  @@index([posicao_id], map: "idx_vagas_posicao")
}

enum convite_status {
  Sugerido
  Confirmado
  Cancelado
}

enum entrevista_status {
  Aguardando_Escolha
  Confirmada
  Cancelada
  Realizada
}

enum etapa_status {
  Em_Andamento @map("Em Andamento")
  Executada
  Pulada
  N_A          @map("N/A")
}

enum origem_candidato {
  Hunting
  Gupy
  Indicacao
  LinkedIn
  Outro
}

enum nivel_senioridade {
  Junior
  Pleno
  Senior
  Especialista
}

/// Decisão final de uma avaliação de entrevista (migrado do app de origem).
enum avaliacao_decisao {
  APROVAR
  REPROVAR
}

enum participacao_tipo {
  Obrigatorio
  Opcional
}

enum processo_status {
  Em_andamento     @map("Em andamento")
  Aprovado
  Reprovado
  Base_de_Talentos @map("Base de Talentos")
}

enum vaga_status {
  Aberta
  Stand_by  @map("Stand-by")
  Fechada
  Cancelada
}

model sessoes {
  id         String   @id
  usuario_id String   @db.Uuid
  expira_em  DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  usuarios   usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
}

// ─────────────────────────────────────────────
// Avaliação de Entrevistas (migrado do people-interview-assessment-agent)
// Fluxo: transcrição → análise comportamental (IA) → recomendação (IA) → decisão.
// A recomendação cruza o candidato atual com o histórico da MESMA posição
// (especialidade) e com entrevistas anteriores do MESMO candidato.
// ─────────────────────────────────────────────
model avaliacoes_entrevista {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Especialidade: vincula a avaliação ao catálogo de posições (posicoes).
  posicao_id           String?              @db.Uuid
  // Processo seletivo de origem (avaliação feita a partir do card do candidato).
  processo_id          String?              @db.Uuid
  candidato_nome       String               @db.VarChar(255)
  cargo                String?              @db.VarChar(500)
  transcricao          String
  // Saídas da IA (JSON) — análise comportamental e recomendação comparativa.
  analise_json         Json?
  recomendacao_json    Json?
  decisao              avaliacao_decisao?
  justificativa_manual String?
  resumo_markdown      String?
  // Id do registro no app de origem — garante idempotência do seed.
  origem_id            Int?                 @unique(map: "uq_avaliacoes_origem")
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime             @default(now()) @db.Timestamptz(6)
  posicoes             posicoes?            @relation(fields: [posicao_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  processos_seletivos  processos_seletivos? @relation(fields: [processo_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([posicao_id], map: "idx_avaliacoes_posicao")
  @@index([processo_id], map: "idx_avaliacoes_processo")
  @@index([candidato_nome], map: "idx_avaliacoes_candidato")
  @@index([created_at], map: "idx_avaliacoes_created")
}

/// Configuração global da IA de avaliação (modelo + prompts). Linha única
/// (`id = "singleton"`). Valores nulos caem nos defaults definidos em código.
model configuracoes_avaliacao {
  id                        String   @id @default("singleton")
  model                     String?
  analysis_prompt           String?
  recommendation_prompt     String?
  summary_prompt            String?
  rejection_template_prompt String?
  updated_at                DateTime @default(now()) @db.Timestamptz(6)
}
